{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "payment-dialog",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "https://starforge-docs.com/r/dialog.json",
    "https://starforge-docs.com/r/button.json",
    "https://starforge-docs.com/r/input.json",
    "https://starforge-docs.com/r/label.json"
  ],
  "files": [
    {
      "path": "src/components/star-forge/dialogs/payment-dialog.tsx",
      "content": "'use client';\n\nimport { Button } from '@/components/ui/button';\nimport {\n  Dialog,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger\n} from '@/components/ui/dialog';\nimport { Input } from '@/components/ui/input';\nimport { Label } from '@/components/ui/label';\nimport { CreditCard } from 'lucide-react';\n\nexport function PaymentDialog() {\n  return (\n    <Dialog>\n      <DialogTrigger asChild>\n        <Button variant=\"outline\">\n          <CreditCard className=\"mr-2 h-4 w-4\" />\n          Payment\n        </Button>\n      </DialogTrigger>\n      <DialogContent className=\"sm:max-w-[425px]\">\n        <DialogHeader>\n          <DialogTitle>Payment method</DialogTitle>\n          <DialogDescription>\n            Add a new payment method to your account. Your card information is\n            encrypted and secure.\n          </DialogDescription>\n        </DialogHeader>\n        <div className=\"grid gap-4 py-4\">\n          <div className=\"grid gap-2\">\n            <Label htmlFor=\"card-name\">Name on card</Label>\n            <Input id=\"card-name\" placeholder=\"John Doe\" />\n          </div>\n          <div className=\"grid gap-2\">\n            <Label htmlFor=\"card-number\">Card number</Label>\n            <Input id=\"card-number\" placeholder=\"0000 0000 0000 0000\" />\n          </div>\n          <div className=\"grid grid-cols-2 gap-4\">\n            <div className=\"grid gap-2\">\n              <Label htmlFor=\"expiry\">Expiry</Label>\n              <Input id=\"expiry\" placeholder=\"MM/YY\" />\n            </div>\n            <div className=\"grid gap-2\">\n              <Label htmlFor=\"cvc\">CVC</Label>\n              <Input id=\"cvc\" placeholder=\"123\" />\n            </div>\n          </div>\n        </div>\n        <DialogFooter>\n          <Button className=\"w-full\">Add Payment Method</Button>\n        </DialogFooter>\n      </DialogContent>\n    </Dialog>\n  );\n}\n\nexport default PaymentDialog;\n",
      "type": "registry:ui"
    }
  ],
  "type": "registry:ui"
}