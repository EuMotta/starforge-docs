{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "payment-dialog",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "https://starforge-docs.com/r/dialog.json",
    "https://starforge-docs.com/r/button.json",
    "https://starforge-docs.com/r/input.json",
    "https://starforge-docs.com/r/label.json"
  ],
  "files": [
    {
      "path": "src/components/star-forge/dialogs/payment-dialog.tsx",
      "content": "'use client';\r\n\r\nimport { Button } from '@/components/ui/button';\r\nimport {\r\n  Dialog,\r\n  DialogContent,\r\n  DialogDescription,\r\n  DialogFooter,\r\n  DialogHeader,\r\n  DialogTitle,\r\n  DialogTrigger\r\n} from '@/components/ui/dialog';\r\nimport { Input } from '@/components/ui/input';\r\nimport { Label } from '@/components/ui/label';\r\nimport { CreditCard } from 'lucide-react';\r\n\r\nexport function PaymentDialog() {\r\n  return (\r\n    <Dialog>\r\n      <DialogTrigger asChild>\r\n        <Button variant=\"outline\">\r\n          <CreditCard className=\"mr-2 h-4 w-4\" />\r\n          Payment\r\n        </Button>\r\n      </DialogTrigger>\r\n      <DialogContent className=\"sm:max-w-[425px]\">\r\n        <DialogHeader>\r\n          <DialogTitle>Payment method</DialogTitle>\r\n          <DialogDescription>\r\n            Add a new payment method to your account. Your card information is\r\n            encrypted and secure.\r\n          </DialogDescription>\r\n        </DialogHeader>\r\n        <div className=\"grid gap-4 py-4\">\r\n          <div className=\"grid gap-2\">\r\n            <Label htmlFor=\"card-name\">Name on card</Label>\r\n            <Input id=\"card-name\" placeholder=\"John Doe\" />\r\n          </div>\r\n          <div className=\"grid gap-2\">\r\n            <Label htmlFor=\"card-number\">Card number</Label>\r\n            <Input id=\"card-number\" placeholder=\"0000 0000 0000 0000\" />\r\n          </div>\r\n          <div className=\"grid grid-cols-2 gap-4\">\r\n            <div className=\"grid gap-2\">\r\n              <Label htmlFor=\"expiry\">Expiry</Label>\r\n              <Input id=\"expiry\" placeholder=\"MM/YY\" />\r\n            </div>\r\n            <div className=\"grid gap-2\">\r\n              <Label htmlFor=\"cvc\">CVC</Label>\r\n              <Input id=\"cvc\" placeholder=\"123\" />\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <DialogFooter>\r\n          <Button className=\"w-full\">Add Payment Method</Button>\r\n        </DialogFooter>\r\n      </DialogContent>\r\n    </Dialog>\r\n  );\r\n}\r\n\r\nexport default PaymentDialog;\r\n",
      "type": "registry:ui"
    }
  ],
  "type": "registry:ui"
}