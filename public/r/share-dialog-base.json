{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "share-dialog-base",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "https://starforge-docs.com/r/base-dialog.json",
    "https://starforge-docs.com/r/base-button.json",
    "https://starforge-docs.com/r/base-input.json",
    "https://starforge-docs.com/r/base-label.json"
  ],
  "files": [
    {
      "path": "src/components/star-forge/dialogs/share-dialog.tsx",
      "content": "'use client';\r\n\r\nimport { Button } from '@/components/ui/button';\r\nimport {\r\n  Dialog,\r\n  DialogContent,\r\n  DialogDescription,\r\n  DialogHeader,\r\n  DialogTitle,\r\n  DialogTrigger\r\n} from '@/components/ui/dialog';\r\nimport { Input } from '@/components/ui/input';\r\nimport { Label } from '@/components/ui/label';\r\nimport { Share2 } from 'lucide-react';\r\n\r\nexport function ShareDialog() {\r\n  return (\r\n    <Dialog>\r\n      <DialogTrigger asChild>\r\n        <Button variant=\"outline\">\r\n          <Share2 className=\"mr-2 h-4 w-4\" />\r\n          Share\r\n        </Button>\r\n      </DialogTrigger>\r\n      <DialogContent className=\"sm:max-w-[425px]\">\r\n        <DialogHeader>\r\n          <DialogTitle>Share this project</DialogTitle>\r\n          <DialogDescription>\r\n            Anyone with the link can view this project. Copy the link below to\r\n            share.\r\n          </DialogDescription>\r\n        </DialogHeader>\r\n        <div className=\"grid gap-4 py-4\">\r\n          <div className=\"grid gap-2\">\r\n            <Label htmlFor=\"share-link\">Project link</Label>\r\n            <div className=\"flex gap-2\">\r\n              <Input\r\n                id=\"share-link\"\r\n                readOnly\r\n                value=\"https://starforge.dev/p/abc123\"\r\n              />\r\n              <Button variant=\"secondary\">Copy</Button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </DialogContent>\r\n    </Dialog>\r\n  );\r\n}\r\n\r\nexport default ShareDialog;\r\n",
      "type": "registry:ui"
    }
  ],
  "type": "registry:ui"
}