{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "welcome-dialog",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "https://starforge-docs.com/r/dialog.json",
    "https://starforge-docs.com/r/button.json"
  ],
  "files": [
    {
      "path": "src/components/star-forge/dialogs/welcome-dialog.tsx",
      "content": "'use client';\r\n\r\nimport { Button } from '@/components/ui/button';\r\nimport {\r\n  Dialog,\r\n  DialogContent,\r\n  DialogDescription,\r\n  DialogFooter,\r\n  DialogHeader,\r\n  DialogTitle,\r\n  DialogTrigger\r\n} from '@/components/ui/dialog';\r\nimport { Sparkles } from 'lucide-react';\r\n\r\nexport function WelcomeDialog() {\r\n  return (\r\n    <Dialog>\r\n      <DialogTrigger asChild>\r\n        <Button variant=\"outline\">\r\n          <Sparkles className=\"mr-2 h-4 w-4\" />\r\n          Welcome\r\n        </Button>\r\n      </DialogTrigger>\r\n      <DialogContent className=\"sm:max-w-[450px]\">\r\n        <DialogHeader>\r\n          <DialogTitle>Welcome to Star Forge</DialogTitle>\r\n          <DialogDescription>\r\n            You are all set! Here is a quick overview of what you can do next.\r\n          </DialogDescription>\r\n        </DialogHeader>\r\n        <div className=\"grid gap-4 py-4\">\r\n          <div className=\"grid grid-cols-3 gap-4 text-center\">\r\n            <div className=\"rounded-lg border p-4\">\r\n              <div className=\"text-2xl font-bold\">1</div>\r\n              <div className=\"text-muted-foreground text-xs\">Create</div>\r\n            </div>\r\n            <div className=\"rounded-lg border p-4\">\r\n              <div className=\"text-2xl font-bold\">2</div>\r\n              <div className=\"text-muted-foreground text-xs\">Customize</div>\r\n            </div>\r\n            <div className=\"rounded-lg border p-4\">\r\n              <div className=\"text-2xl font-bold\">3</div>\r\n              <div className=\"text-muted-foreground text-xs\">Deploy</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <DialogFooter>\r\n          <Button className=\"w-full\">Get Started</Button>\r\n        </DialogFooter>\r\n      </DialogContent>\r\n    </Dialog>\r\n  );\r\n}\r\n\r\nexport default WelcomeDialog;\r\n",
      "type": "registry:ui"
    }
  ],
  "type": "registry:ui"
}