{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "feedback-dialog",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "https://starforge-docs.com/r/dialog.json",
    "https://starforge-docs.com/r/button.json",
    "https://starforge-docs.com/r/label.json",
    "https://starforge-docs.com/r/textarea.json"
  ],
  "files": [
    {
      "path": "src/components/star-forge/dialogs/feedback-dialog.tsx",
      "content": "'use client';\r\n\r\nimport { Button } from '@/components/ui/button';\r\nimport {\r\n  Dialog,\r\n  DialogContent,\r\n  DialogDescription,\r\n  DialogFooter,\r\n  DialogHeader,\r\n  DialogTitle,\r\n  DialogTrigger\r\n} from '@/components/ui/dialog';\r\nimport { Label } from '@/components/ui/label';\r\nimport { Textarea } from '@/components/ui/textarea';\r\nimport { MessageSquare } from 'lucide-react';\r\n\r\nexport function FeedbackDialog() {\r\n  return (\r\n    <Dialog>\r\n      <DialogTrigger asChild>\r\n        <Button variant=\"outline\">\r\n          <MessageSquare className=\"mr-2 h-4 w-4\" />\r\n          Feedback\r\n        </Button>\r\n      </DialogTrigger>\r\n      <DialogContent className=\"sm:max-w-[425px]\">\r\n        <DialogHeader>\r\n          <DialogTitle>Send feedback</DialogTitle>\r\n          <DialogDescription>\r\n            Let us know how we can improve your experience. Your feedback helps\r\n            us build better tools.\r\n          </DialogDescription>\r\n        </DialogHeader>\r\n        <div className=\"grid gap-4 py-4\">\r\n          <div className=\"grid gap-2\">\r\n            <Label htmlFor=\"feedback\">Your feedback</Label>\r\n            <Textarea\r\n              id=\"feedback\"\r\n              placeholder=\"Tell us what you think...\"\r\n              className=\"min-h-[100px]\"\r\n            />\r\n          </div>\r\n        </div>\r\n        <DialogFooter>\r\n          <Button>Send Feedback</Button>\r\n        </DialogFooter>\r\n      </DialogContent>\r\n    </Dialog>\r\n  );\r\n}\r\n\r\nexport default FeedbackDialog;\r\n",
      "type": "registry:ui"
    }
  ],
  "type": "registry:ui"
}