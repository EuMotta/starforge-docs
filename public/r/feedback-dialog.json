{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "feedback-dialog",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "https://starforge-docs.com/r/dialog.json",
    "https://starforge-docs.com/r/button.json",
    "https://starforge-docs.com/r/label.json",
    "https://starforge-docs.com/r/textarea.json"
  ],
  "files": [
    {
      "path": "src/components/star-forge/dialogs/feedback-dialog.tsx",
      "content": "'use client';\n\nimport { Button } from '@/components/ui/button';\nimport {\n  Dialog,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger\n} from '@/components/ui/dialog';\nimport { Label } from '@/components/ui/label';\nimport { Textarea } from '@/components/ui/textarea';\nimport { MessageSquare } from 'lucide-react';\n\nexport function FeedbackDialog() {\n  return (\n    <Dialog>\n      <DialogTrigger asChild>\n        <Button variant=\"outline\">\n          <MessageSquare className=\"mr-2 h-4 w-4\" />\n          Feedback\n        </Button>\n      </DialogTrigger>\n      <DialogContent className=\"sm:max-w-[425px]\">\n        <DialogHeader>\n          <DialogTitle>Send feedback</DialogTitle>\n          <DialogDescription>\n            Let us know how we can improve your experience. Your feedback helps\n            us build better tools.\n          </DialogDescription>\n        </DialogHeader>\n        <div className=\"grid gap-4 py-4\">\n          <div className=\"grid gap-2\">\n            <Label htmlFor=\"feedback\">Your feedback</Label>\n            <Textarea\n              id=\"feedback\"\n              placeholder=\"Tell us what you think...\"\n              className=\"min-h-[100px]\"\n            />\n          </div>\n        </div>\n        <DialogFooter>\n          <Button>Send Feedback</Button>\n        </DialogFooter>\n      </DialogContent>\n    </Dialog>\n  );\n}\n\nexport default FeedbackDialog;\n",
      "type": "registry:ui"
    }
  ],
  "type": "registry:ui"
}