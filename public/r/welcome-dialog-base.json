{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "welcome-dialog-base",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "https://starforge-docs.com/r/base-dialog.json",
    "https://starforge-docs.com/r/base-button.json"
  ],
  "files": [
    {
      "path": "src/components/star-forge/dialogs/welcome-dialog.tsx",
      "content": "'use client';\n\nimport { Button } from '@/components/ui/button';\nimport {\n  Dialog,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger\n} from '@/components/ui/dialog';\nimport { Sparkles } from 'lucide-react';\n\nexport function WelcomeDialog() {\n  return (\n    <Dialog>\n      <DialogTrigger asChild>\n        <Button variant=\"outline\">\n          <Sparkles className=\"mr-2 h-4 w-4\" />\n          Welcome\n        </Button>\n      </DialogTrigger>\n      <DialogContent className=\"sm:max-w-[450px]\">\n        <DialogHeader>\n          <DialogTitle>Welcome to Star Forge</DialogTitle>\n          <DialogDescription>\n            You are all set! Here is a quick overview of what you can do next.\n          </DialogDescription>\n        </DialogHeader>\n        <div className=\"grid gap-4 py-4\">\n          <div className=\"grid grid-cols-3 gap-4 text-center\">\n            <div className=\"rounded-lg border p-4\">\n              <div className=\"text-2xl font-bold\">1</div>\n              <div className=\"text-muted-foreground text-xs\">Create</div>\n            </div>\n            <div className=\"rounded-lg border p-4\">\n              <div className=\"text-2xl font-bold\">2</div>\n              <div className=\"text-muted-foreground text-xs\">Customize</div>\n            </div>\n            <div className=\"rounded-lg border p-4\">\n              <div className=\"text-2xl font-bold\">3</div>\n              <div className=\"text-muted-foreground text-xs\">Deploy</div>\n            </div>\n          </div>\n        </div>\n        <DialogFooter>\n          <Button className=\"w-full\">Get Started</Button>\n        </DialogFooter>\n      </DialogContent>\n    </Dialog>\n  );\n}\n\nexport default WelcomeDialog;\n",
      "type": "registry:ui"
    }
  ],
  "type": "registry:ui"
}